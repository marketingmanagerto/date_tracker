datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// ---- Auth (NextAuth v5 standard tables) ----

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts         Account[]
  sessions         Session[]
  reminders        Reminder[]
  categories       Category[]
  settings         UserSettings?
  notificationLogs NotificationLog[]
  expenses         Expense[]
  recurringTasks   RecurringTask[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ---- Core App Models ----

model Category {
  id                String         @id @default(cuid())
  userId            String
  name              String
  slug              String
  icon              String
  color             String
  isSystem          Boolean        @default(false)
  defaultRecurrence RecurrenceType @default(NONE)
  createdAt         DateTime       @default(now())

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  reminders Reminder[]

  @@unique([userId, slug])
}

model Reminder {
  id         String @id @default(cuid())
  userId     String
  categoryId String

  title    String
  notes    String?
  date     DateTime
  isAllDay Boolean  @default(true)

  recurrenceType RecurrenceType @default(NONE)
  rruleString    String?

  advanceDays Int            @default(7)
  priority    Priority       @default(MEDIUM)
  status      ReminderStatus @default(ACTIVE)
  snoozedUntil DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  category         Category          @relation(fields: [categoryId], references: [id])
  notificationLogs NotificationLog[]
}

enum RecurrenceType {
  NONE
  DAILY
  WEEKLY
  MONTHLY
  YEARLY
  CUSTOM
}

enum Priority {
  LOW
  MEDIUM
  HIGH
}

enum ReminderStatus {
  ACTIVE
  SNOOZED
  ARCHIVED
}

model UserSettings {
  id                   String          @id @default(cuid())
  userId               String          @unique
  emailNotifications   Boolean         @default(true)
  defaultAdvanceDays   Int             @default(7)
  digestTime           String          @default("08:00")
  timezone             String          @default("UTC")
  emailDigestFrequency DigestFrequency @default(DAILY)
  discordNotifications Boolean         @default(false)
  discordWebhookUrl    String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum DigestFrequency {
  DAILY
  WEEKLY
  NONE
}

// ---- Recurring Tasks ----

enum RecurringInterval {
  HOURLY
  DAILY
  WEEKLY
  MONTHLY
  YEARLY
}

enum RecurringStatus {
  ACTIVE
  PAUSED
}

model RecurringTask {
  id             String            @id @default(cuid())
  userId         String
  user           User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  title          String
  notes          String?
  interval       RecurringInterval @default(DAILY)
  intervalValue  Int               @default(1) // every N intervals
  nextFireAt     DateTime          // maintained by cron
  lastFiredAt    DateTime?
  notifyEmail    Boolean           @default(true)
  notifyDiscord  Boolean           @default(false)
  status         RecurringStatus   @default(ACTIVE)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  @@index([userId])
  @@index([nextFireAt, status])
}

// ---- Expenses ----

enum ExpenseType {
  PERSONAL
  BUSINESS
}

enum ExpenseFrequency {
  DAILY
  WEEKLY
  MONTHLY
  QUARTERLY
  YEARLY
  ONE_TIME
}

enum ExpenseStatus {
  ACTIVE
  PAUSED
  CANCELLED
}

model Expense {
  id          String           @id @default(cuid())
  userId      String
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String
  amount      Decimal          @db.Decimal(10, 2)
  type        ExpenseType      @default(PERSONAL)
  card        String           // e.g. "Visa 4242", "Amex Gold", "Bank Transfer"
  frequency   ExpenseFrequency @default(MONTHLY)
  nextDueDate DateTime
  category    String           // free-text: "Software", "Utilities", "Streaming", etc.
  notes       String?
  status      ExpenseStatus    @default(ACTIVE)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@index([userId])
}

model NotificationLog {
  id         String   @id @default(cuid())
  userId     String
  reminderId String
  sentAt     DateTime @default(now())
  type       String
  subject    String?
  success    Boolean  @default(true)
  error      String?

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  reminder Reminder @relation(fields: [reminderId], references: [id], onDelete: Cascade)
}
