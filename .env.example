# Database — used by the app at runtime
# If using the bundled postgres in docker-compose, use:
#   postgresql://datetracker:<POSTGRES_PASSWORD>@db:5432/datetracker
DATABASE_URL="postgresql://username:password@host:5432/dbname"

# Postgres container credentials (docker-compose only)
POSTGRES_DB="datetracker"
POSTGRES_USER="datetracker"
POSTGRES_PASSWORD="change-me"

# NextAuth
NEXTAUTH_SECRET="generate-with: openssl rand -base64 32"
NEXTAUTH_URL="https://yourdomain.com"

# Google OAuth (optional — leave blank to disable)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Resend (email sending) — get from resend.com
RESEND_API_KEY=""
RESEND_FROM_EMAIL="reminders@yourdomain.com"

# Cron secret — used to authenticate the daily-digest cron call
# generate-with: openssl rand -base64 32
CRON_SECRET=""

# App URL (used in emails and OAuth redirects)
NEXT_PUBLIC_APP_URL="https://yourdomain.com"

# Port exposed by the app container (default 3000)
APP_PORT=3000
